# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local

# Cursor agent/session notes (not product documentation)
.cursor/*.md
.cursor/plans/

# IDE
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
coverage/

# Drizzle
drizzle/meta/
*.sqlite
.drizzle/

# Drizzle introspect output (canonical schema lives in packages/db/src/schema-platform/)
packages/db/src/migrations/schema.ts
packages/db/src/migrations/relations.ts

# Drizzle push artifacts (prevent accidental commits)
packages/db/src/migrations/**/push-*
packages/db/src/migrations/**/.push-*

# Temporary migration files
packages/db/src/migrations/**/*.tmp
packages/db/src/migrations/**/*-temp.sql

# Temporary files
*.tmp
*.temp
.cache/

# Local compliance / audit scratch output (repo root; do not commit)
/_compliance*.json
/_compliance-full.txt
/compliance-out.txt
