# -----------------------------------------------------------------------------
# AFENDA Hybrid - environment template
#
# Setup: copy to .env and edit. .env is gitignored; never commit secrets.
# drizzle.config.ts loads .env with override: true (values here beat shell).
# -----------------------------------------------------------------------------

# --- Database (required for Drizzle, migrations, db tests) --------------------

# Use ONE active DATABASE_URL for your machine.

# Docker test DB (pnpm docker:test:start / pnpm docker:test:reset) - port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/afenda_test

# Local Postgres (default install) - uncomment and adjust user/password/database
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/afenda_dev

# --- Database Admin (optional, for migrations with RLS) -----------------------

# When RLS is enabled, the application role (DATABASE_URL) cannot run migrations.
# Set DATABASE_URL_ADMIN to a superuser or owner role for drizzle-kit operations.
# If not set, drizzle.config.ts falls back to DATABASE_URL.
#
# Docker test DB (same as DATABASE_URL since postgres is superuser):
# DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5433/afenda_test
#
# Production pattern (separate admin role):
# DATABASE_URL_ADMIN=postgresql://afenda_admin:ADMIN_PASSWORD@localhost:5432/afenda

# --- Optional: GitHub API (developer tooling only) ------------------------------

# Not used by the schema/runtime code in this repo. Set here if you want a
# single PAT available when tools read project .env (e.g. some local scripts).
# Cursor GitHub MCP: configure in Cursor MCP / OS env - it does not load this file.
# Fine-grained PAT: grant repository/metadata access as needed for your workflows.
# GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Optional: safety / scripts (uncomment only when needed) ------------------

# scripts/reset-test-db.ts: allow reset when DB name is not fenda_test
# AFENDA_FORCE_DB_RESET=1