# Database connection — pick ONE URL for your environment.

# Docker test DB (pnpm docker:test:start / docker:test:reset) — port 5433, DB afenda_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/afenda_test

# Local Postgres (default install) — adjust user/password/DB as needed
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/afenda_dev
