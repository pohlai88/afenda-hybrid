{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afenda.com/schemas/custom-sql-registry.json",
  "title": "Custom SQL Registry",
  "description": "Registry of all custom SQL blocks that cannot be expressed in Drizzle ORM schema language",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Registry version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this registry"
    },
    "entries": {
      "type": "object",
      "description": "Map of CSQL-XXX IDs to custom SQL entries",
      "patternProperties": {
        "^CSQL-\\d+$": {
          "type": "object",
          "properties": {
            "purpose": {
              "type": "string",
              "description": "Human-readable description of what this custom SQL does",
              "minLength": 10
            },
            "migration": {
              "type": "string",
              "description": "Migration name where this custom SQL appears (e.g., 20260319144405_gifted_ultragirl)",
              "pattern": "^\\d{14}_[a-z_]+$"
            },
            "type": {
              "type": "string",
              "description": "Type of custom SQL",
              "enum": [
                "PARTITION",
                "TRIGGER",
                "TRIGGER_FUNCTION",
                "FUNCTION",
                "PROCEDURE",
                "INDEX",
                "POLICY",
                "CONSTRAINT",
                "EXTENSION",
                "OTHER"
              ]
            },
            "justification": {
              "type": "string",
              "description": "Explanation of why Drizzle cannot express this feature",
              "minLength": 20
            },
            "rollback": {
              "type": "string",
              "description": "Step-by-step procedure to rollback this custom SQL",
              "minLength": 10
            },
            "approvedBy": {
              "type": "string",
              "description": "Team or person who approved this custom SQL (e.g., dba-team, @username)"
            },
            "approvedDate": {
              "type": "string",
              "description": "Date of approval in ISO 8601 format (YYYY-MM-DD)",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "sqlLines": {
              "type": "string",
              "description": "Line range in migration file where this SQL appears (e.g., 149-181)",
              "pattern": "^\\d+-\\d+$|^TBD$"
            },
            "performanceImpact": {
              "type": "string",
              "description": "Optional: Assessment of performance impact",
              "enum": ["LOW", "MEDIUM", "HIGH", "UNKNOWN"]
            },
            "securityReview": {
              "type": "boolean",
              "description": "Optional: Whether this has undergone security review"
            },
            "notes": {
              "type": "string",
              "description": "Optional: Additional notes or context"
            }
          },
          "required": ["purpose", "migration", "type", "justification", "rollback"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["version", "entries"],
  "additionalProperties": false
}
