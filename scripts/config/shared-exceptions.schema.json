{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Shared Column Exceptions",
  "description": "Schema for shared-exceptions.json - defines allowed bypasses of shared column mixins",
  "type": "object",
  "required": ["exceptions"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "table", "column", "rule", "reason", "owner", "date"],
        "properties": {
          "file": {
            "type": "string",
            "description": "Relative path to the schema file"
          },
          "table": {
            "type": "string",
            "description": "Table name (snake_case)"
          },
          "column": {
            "type": "string",
            "description": "Column name being excepted"
          },
          "rule": {
            "type": "string",
            "enum": ["use-timestamp-mixin", "use-tenant-mixin", "use-audit-mixin", "use-softdelete-mixin"],
            "description": "The CI rule being bypassed"
          },
          "reason": {
            "type": "string",
            "minLength": 10,
            "description": "Detailed justification for the exception"
          },
          "owner": {
            "type": "string",
            "description": "Team or person responsible for this exception"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date exception was added (YYYY-MM-DD)"
          }
        }
      }
    }
  }
}
