{
  "name": "@afenda/erp-view-pack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AFENDA ERP View Pack — ERP-specific patterns, widgets, and presets",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./patterns/*": {
      "types": "./src/patterns/*.tsx",
      "default": "./src/patterns/*.tsx"
    },
    "./widgets/*": {
      "types": "./src/widgets/*.tsx",
      "default": "./src/widgets/*.tsx"
    },
    "./selection": {
      "types": "./src/selection/index.ts",
      "default": "./src/selection/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env NODE_OPTIONS='--max-old-space-size=4096' vitest run",
    "test:watch": "vitest --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "catalog:",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@afenda/ui-core": "workspace:*",
    "@afenda/view-engine": "workspace:*",
    "lucide-react": "^0.468.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
