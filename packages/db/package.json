{
  "name": "@afenda/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate --ignore-conflicts",
    "db:push": "echo '❌ db:push is disabled. Use db:generate + db:migrate instead.' && echo 'For local dev only, use: pnpm db:push:unsafe' && exit 1",
    "db:push:unsafe": "echo '⚠️  WARNING: This bypasses schema lockdown. Do not use in production!' && echo 'Press Ctrl+C to cancel, or wait 5 seconds...' && sleep 5 && drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:drift-check": "tsx scripts/ci/detect-schema-drift.ts",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/_seeds/run.ts",
    "db:bootstrap": "tsx src/_seeds/run.ts bootstrap",
    "db:verify-exports": "tsx scripts/ci/verify-zod-exports.ts",
    "db:analyze": "tsx scripts/lib/schema-analyzer.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:db": "vitest run",
    "test:db:recreate": "tsx scripts/prepare/reset-test-db.ts",
    "test:db:smoke": "vitest run --testNamePattern=smoke",
    "test:db:contracts": "vitest run --testNamePattern=contract",
    "test:db:contracts:clean": "pnpm test:db:recreate && pnpm test:db:contracts",
    "test:db:enums": "vitest run --testNamePattern=enum",
    "test:db:tenant-isolation": "vitest run --testNamePattern=tenant",
    "test:db:constraints": "vitest run --testNamePattern=constraint",
    "test:db:fk-cascades": "vitest run --testNamePattern=cascade",
    "test:db:query-plans": "vitest run --testNamePattern=query-plan",
    "docker:test:start": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command start",
    "docker:test:stop": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command stop",
    "docker:test:down": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command down",
    "docker:test:reset": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command reset",
    "docker:test:status": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command status",
    "docker:test:shell": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command shell",
    "docker:test:logs": "powershell -ExecutionPolicy Bypass -File scripts/ops/docker-test-db.ps1 -Command logs",
    "check:naming": "tsx scripts/ci/check-naming-conventions.ts",
    "check:structure": "tsx scripts/ci/validate-schema-structure.ts",
    "check:compliance": "tsx scripts/ci/check-guideline-compliance-v2.ts",
    "check:tenant": "tsx scripts/ci/check-tenant-isolation.ts",
    "check:constraints": "tsx scripts/ci/check-constraint-patterns.ts",
    "check:shared": "tsx scripts/ci/check-shared-columns.ts",
    "check:indexes": "tsx scripts/ci/check-index-patterns.ts",
    "check:relations": "tsx scripts/ci/check-relations-completeness.ts",
    "check:migrations": "tsx scripts/ci/validate-migrations.ts",
    "check:drift": "tsx scripts/ci/detect-schema-drift.ts",
    "check:enums": "tsx scripts/ci/check-enums.ts",
    "check:cross-schema": "tsx scripts/ci/check-cross-schema.ts",
    "check:breaking-changes": "tsx scripts/ci/check-breaking-changes.ts",
    "check:custom-sql-registry": "tsx scripts/ci/check-custom-sql-registry.ts",
    "check:security": "tsx scripts/ci/check-security.ts",
    "check:branded-ids": "tsx scripts/ci/check-branded-ids.ts",
    "check:type-inference": "tsx scripts/ci/check-type-inference.ts",
    "check:custom-sql-syntax": "tsx scripts/ci/check-custom-sql-syntax.ts",
    "check:rls-policies": "tsx scripts/ci/check-rls-policies.ts",
    "check:docs-sync": "tsx scripts/ci/check-docs-sync.ts",
    "check:hr-audit-matrix": "tsx scripts/ci/verify-hr-schema-audit-matrix.ts",
    "check:csql014-preflight": "tsx scripts/preflight/check-csql-014-preflight.ts",
    "check:reviews-lifecycle-preflight": "tsx scripts/preflight/check-performance-reviews-lifecycle-preflight.ts",
    "check:promotion-records-preflight": "tsx scripts/preflight/check-promotion-records-preflight.ts",
    "check:grievance-resolution-preflight": "tsx scripts/preflight/check-grievance-resolution-preflight.ts",
    "check:learning-cert-lifecycle-preflight": "tsx scripts/preflight/check-learning-cert-lifecycle-preflight.ts",
    "check:succession-plans-preflight": "tsx scripts/preflight/check-succession-plans-preflight.ts",
    "check:preflight": "tsx scripts/preflight/run-all-preflights.ts",
    "report:succession-plans-development-gap": "tsx scripts/report/report-succession-plans-development-gap.ts",
    "report:case-links-integrity": "tsx scripts/report/report-case-links-integrity.ts",
    "db:prepare": "tsx scripts/prepare/prepare-migration.ts",
    "db:apply-rls": "tsx scripts/prepare/apply-rls.ts",
    "check:naming:strict": "tsx scripts/ci/check-naming-conventions.ts --strict-warnings",
    "check:structure:strict": "tsx scripts/ci/validate-schema-structure.ts --strict-warnings",
    "check:compliance:strict": "tsx scripts/ci/check-guideline-compliance-v2.ts --strict-warnings",
    "check:tenant:strict": "tsx scripts/ci/check-tenant-isolation.ts --strict-warnings",
    "check:constraints:strict": "tsx scripts/ci/check-constraint-patterns.ts --strict-warnings",
    "check:shared:strict": "tsx scripts/ci/check-shared-columns.ts --strict-warnings",
    "check:indexes:strict": "tsx scripts/ci/check-index-patterns.ts --strict-warnings",
    "check:relations:strict": "tsx scripts/ci/check-relations-completeness.ts --strict-warnings",
    "check:all": "pnpm check:naming && pnpm check:structure && pnpm check:compliance && pnpm check:tenant && pnpm check:constraints && pnpm check:shared && pnpm check:indexes && pnpm check:relations && pnpm check:enums && pnpm check:cross-schema && pnpm check:hr-audit-matrix && pnpm check:security && pnpm check:branded-ids && pnpm check:type-inference && pnpm check:custom-sql-registry && pnpm check:rls-policies && pnpm check:docs-sync && pnpm check:breaking-changes",
    "check:all:strict": "pnpm check:naming:strict && pnpm check:structure:strict && pnpm check:compliance:strict && pnpm check:tenant:strict && pnpm check:constraints:strict && pnpm check:shared:strict && pnpm check:indexes:strict && pnpm check:relations:strict && pnpm check:enums:strict && pnpm check:cross-schema:strict",
    "check:enums:strict": "tsx scripts/ci/check-enums.ts --strict-warnings",
    "check:cross-schema:strict": "tsx scripts/ci/check-cross-schema.ts --strict-warnings",
    "fix:schema": "tsx scripts/prepare/auto-fix-schema.ts",
    "fix:schema:dry": "tsx scripts/prepare/auto-fix-schema.ts --dry-run",
    "fix:lint": "pnpm lint:fix && pnpm format",
    "fix:all": "pnpm fix:schema && pnpm fix:lint",
    "gate:early": "pnpm typecheck && pnpm db:check && pnpm db:verify-exports && pnpm check:all && pnpm check:migrations && pnpm check:drift",
    "gate:strict": "pnpm typecheck && pnpm db:check && pnpm db:verify-exports && pnpm check:all:strict && pnpm check:migrations && pnpm check:drift",
    "gate:early:fix": "pnpm fix:schema && pnpm gate:early",
    "gate:lint": "pnpm lint && pnpm format:check",
    "gate:types": "pnpm typecheck && pnpm db:check && pnpm db:verify-exports && pnpm check:branded-ids && pnpm check:type-inference",
    "gate:conventions": "pnpm check:naming && pnpm check:structure && pnpm check:compliance && pnpm check:constraints && pnpm check:shared && pnpm check:enums",
    "gate:architecture": "pnpm check:tenant && pnpm check:indexes && pnpm check:relations && pnpm check:cross-schema",
    "gate:security": "pnpm check:security && pnpm check:rls-policies",
    "gate:migrations": "pnpm check:migrations && pnpm check:drift && pnpm check:breaking-changes && pnpm check:custom-sql-registry",
    "gate:docs": "pnpm check:docs-sync && pnpm check:hr-audit-matrix",
    "gate:full": "pnpm gate:lint && pnpm gate:types && pnpm gate:conventions && pnpm gate:architecture && pnpm gate:security && pnpm gate:migrations && pnpm gate:docs",
    "gate:360": "pnpm gate:full && pnpm check:custom-sql-syntax && pnpm check:preflight && pnpm test:db",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "pg": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
