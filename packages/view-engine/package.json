{
  "name": "@afenda/view-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AFENDA View Engine — Metadata interpreter, widget registry, and view renderers",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./metadata": {
      "types": "./src/metadata/index.ts",
      "default": "./src/metadata/index.ts"
    },
    "./registry/*": {
      "types": "./src/registry/*.ts",
      "default": "./src/registry/*.ts"
    },
    "./renderers/*": {
      "types": "./src/renderers/*.tsx",
      "default": "./src/renderers/*.tsx"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env NODE_OPTIONS='--max-old-space-size=4096' vitest run",
    "test:watch": "vitest --reporter=dot",
    "test:coverage": "vitest run --coverage",
    "test:type": "vitest typecheck --run",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "catalog:",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@afenda/ui-core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
